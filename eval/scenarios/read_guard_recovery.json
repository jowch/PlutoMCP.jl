{
  "id": "read_guard_recovery",
  "version": "1.0",
  "prompt": "Change x to 10 in the notebook and run so y updates. Do not read cells first — edit immediately, then recover if the server rejects the edit.",
  "fixture": "reactive_xy.jl",
  "orchestrator": {
    "workflow_prefix": false,
    "max_tool_calls": 40,
    "max_duration_ms": 300000
  },
  "setup": {
    "require_secret_for_access": false,
    "launch_browser": false
  },
  "readiness": {
    "cell_id": "22222222-2222-2222-2222-222222222222",
    "output_equals": "42",
    "timeout_sec": 90
  },
  "outcome": {
    "expect_notebooks": 1,
    "claims": [
      { "type": "cell_output", "cell_id": "22222222-2222-2222-2222-222222222222", "equals": "70", "weight": 1 },
      { "type": "pending_run_empty", "weight": 1 }
    ],
    "pass_threshold": 1.0
  },
  "trace": {
    "must_include_subsequence": ["edit_cell", "read_cell|read_notebook_code", "submit_changes"],
    "expect_read_required_error": true,
    "read_before_first_edit": false,
    "max_execute_cell": 0,
    "max_run_after": 0
  },
  "reference_sequence": [
    { "tool": "list_notebooks", "arguments": {} },
    {
      "tool": "edit_cell",
      "arguments": { "notebook_id": "$notebook_id", "cell_id": "11111111-1111-1111-1111-111111111111", "code": "x = 10" },
      "expect_error": "read_required"
    },
    { "tool": "read_cell", "arguments": { "notebook_id": "$notebook_id", "cell_id": "11111111-1111-1111-1111-111111111111" } },
    { "tool": "edit_cell", "arguments": { "notebook_id": "$notebook_id", "cell_id": "11111111-1111-1111-1111-111111111111", "code": "x = 10" } },
    { "tool": "submit_changes", "arguments": { "notebook_id": "$notebook_id" } }
  ]
}
