{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlutoMCP eval scenario",
  "type": "object",
  "required": ["id", "version", "prompt", "fixture", "outcome"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "prompt": { "type": "string" },
    "fixture": { "type": "string" },
    "orchestrator": {
      "type": "object",
      "properties": {
        "workflow_prefix": { "type": "boolean", "default": true },
        "max_tool_calls": { "type": "integer" },
        "max_duration_ms": { "type": "integer" }
      }
    },
    "setup": {
      "type": "object",
      "properties": {
        "require_secret_for_access": { "type": "boolean" },
        "launch_browser": { "type": "boolean" }
      }
    },
    "readiness": {
      "type": "object",
      "properties": {
        "cell_id": { "type": "string" },
        "output_equals": { "type": "string" },
        "timeout_sec": { "type": "number", "default": 90 }
      }
    },
    "outcome": {
      "type": "object",
      "required": ["claims"],
      "properties": {
        "expect_notebooks": { "type": "integer", "default": 1 },
        "claims": { "type": "array" },
        "pass_threshold": { "type": "number", "default": 1.0 }
      }
    },
    "trace": { "type": "object" },
    "golden_trace_ref": { "type": "string" },
    "reference_sequence": {
      "type": "array",
      "description": "Golden-path tool calls for run_reference.jl"
    }
  }
}
