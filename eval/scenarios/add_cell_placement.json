{
  "id": "add_cell_placement",
  "version": "1.0",
  "prompt": "Add a new cell after x that defines z = x + 1. Stage and run the notebook. Use Pluto MCP tools.",
  "fixture": "single_anchor.jl",
  "orchestrator": {
    "workflow_prefix": true,
    "max_tool_calls": 40,
    "max_duration_ms": 300000
  },
  "setup": {
    "require_secret_for_access": false,
    "launch_browser": false
  },
  "readiness": {
    "cell_id": "11111111-1111-1111-1111-111111111111",
    "output_equals": "6",
    "timeout_sec": 90
  },
  "outcome": {
    "expect_notebooks": 1,
    "claims": [
      { "type": "cell_order_after", "anchor_cell_id": "11111111-1111-1111-1111-111111111111", "new_code_contains": "z = x + 1", "weight": 1 },
      { "type": "projection_contains", "substring": "z = x + 1", "weight": 1 },
      { "type": "pending_run_empty", "weight": 1 }
    ],
    "pass_threshold": 1.0
  },
  "trace": {
    "must_include_subsequence": ["read_cell|read_notebook_code", "add_cell", "submit_changes"],
    "must_not_include": ["run_all_cells"],
    "read_before_first_edit": true,
    "max_execute_cell": 0,
    "max_run_after": 0
  },
  "reference_sequence": [
    { "tool": "list_notebooks", "arguments": {} },
    { "tool": "read_cell", "arguments": { "notebook_id": "$notebook_id", "cell_id": "11111111-1111-1111-1111-111111111111" } },
    {
      "tool": "add_cell",
      "arguments": {
        "notebook_id": "$notebook_id",
        "code": "z = x + 1",
        "after_cell_id": "11111111-1111-1111-1111-111111111111"
      }
    },
    { "tool": "submit_changes", "arguments": { "notebook_id": "$notebook_id" } }
  ]
}
