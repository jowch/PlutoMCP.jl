{
  "id": "stage_and_run",
  "version": "1.0",
  "prompt": "The notebook defines x=6 and y=x*7. Change x to 10 and run so y updates. Use Pluto MCP tools.",
  "fixture": "reactive_xy.jl",
  "orchestrator": {
    "workflow_prefix": true,
    "max_tool_calls": 40,
    "max_duration_ms": 300000
  },
  "setup": {
    "require_secret_for_access": false,
    "launch_browser": false
  },
  "readiness": {
    "cell_id": "22222222-2222-2222-2222-222222222222",
    "output_equals": "42",
    "timeout_sec": 90
  },
  "outcome": {
    "expect_notebooks": 1,
    "claims": [
      { "type": "cell_code_contains", "cell_id": "11111111-1111-1111-1111-111111111111", "substring": "x = 10", "weight": 1 },
      { "type": "cell_output", "cell_id": "22222222-2222-2222-2222-222222222222", "equals": "70", "weight": 1 },
      { "type": "pending_run_empty", "weight": 1 }
    ],
    "pass_threshold": 1.0
  },
  "trace": {
    "must_include_subsequence": ["read_notebook_code|read_cell", "edit_cell|edit_cells", "submit_changes"],
    "must_not_include": ["run_all_cells"],
    "max_execute_cell": 0,
    "read_before_first_edit": true
  },
  "golden_trace_ref": "golden/stage_and_run.jsonl",
  "reference_sequence": [
    { "tool": "list_notebooks", "arguments": {} },
    { "tool": "read_notebook_code", "arguments": { "notebook_id": "$notebook_id" } },
    { "tool": "edit_cell", "arguments": { "notebook_id": "$notebook_id", "cell_id": "11111111-1111-1111-1111-111111111111", "code": "x = 10" } },
    { "tool": "submit_changes", "arguments": { "notebook_id": "$notebook_id" } }
  ]
}
