{
  "id": "batch_edit",
  "version": "1.0",
  "prompt": "The notebook has a=1, b=2, and c=a+b. Change a to 10 and b to 20, then run so c updates. Use Pluto MCP tools.",
  "fixture": "batch_abc.jl",
  "orchestrator": {
    "workflow_prefix": true,
    "max_tool_calls": 40,
    "max_duration_ms": 300000
  },
  "setup": {
    "require_secret_for_access": false,
    "launch_browser": false
  },
  "readiness": {
    "cell_id": "55555555-5555-5555-5555-555555555555",
    "output_equals": "3",
    "timeout_sec": 90
  },
  "outcome": {
    "expect_notebooks": 1,
    "claims": [
      { "type": "cell_output", "cell_id": "55555555-5555-5555-5555-555555555555", "equals": "30", "weight": 1 },
      { "type": "pending_run_empty", "weight": 1 }
    ],
    "pass_threshold": 1.0
  },
  "trace": {
    "must_include_subsequence": ["read_notebook_code|read_cell", "edit_cells|edit_cell", "submit_changes"],
    "must_not_include": ["run_all_cells"],
    "max_execute_cell": 0,
    "read_before_first_edit": true
  },
  "reference_sequence": [
    { "tool": "list_notebooks", "arguments": {} },
    { "tool": "read_notebook_code", "arguments": { "notebook_id": "$notebook_id" } },
    {
      "tool": "edit_cells",
      "arguments": {
        "notebook_id": "$notebook_id",
        "cells": [
          { "cell_id": "33333333-3333-3333-3333-333333333333", "code": "a = 10" },
          { "cell_id": "44444444-4444-4444-4444-444444444444", "code": "b = 20" }
        ]
      }
    },
    { "tool": "submit_changes", "arguments": { "notebook_id": "$notebook_id" } }
  ]
}
